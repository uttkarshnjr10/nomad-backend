nomad-frontend/dist/
nomad-frontend/build/

# Local env files
.env.local
.env.development.local
.env.test.local
.env.production.local

# ------------------------------------------------------
# BACKEND - JAVA (Auth Service)
# ------------------------------------------------------
# Compiled class files
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Maven target folder (where the build happens)
auth-service/target/
target/

# Eclipse/IntelliJ project files generated by Maven
.classpath
.project
.settings/
*.iml

# ------------------------------------------------------
# BACKEND - CONTENT SERVICE (Uploads)
# ------------------------------------------------------
# Ignore actual uploaded files, but keep the directory structure
content-service/public/temp/*
!content-service/public/temp/.gitkeep

